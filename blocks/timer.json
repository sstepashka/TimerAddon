{
  "format_version": "1.21.10",
  "minecraft:block": {
    "description": {
      "identifier": "custom:timer",
      "menu_category": {
        "category": "construction",
        "group": "itemGroup.name.redstone"
      },
      "states": {
        "custom:is_active": [false, true],
        "custom:is_finished": [false, true]
      }
    },
    "components": {
      "minecraft:geometry": "minecraft:geometry.full_block",
      "minecraft:material_instances": {
        "*": {
          "texture": "planks",
          "render_method": "opaque"
        }
      },
      "minecraft:custom_components": ["custom:timer_logic"],
      "minecraft:tick": {
        "interval_range": [1, 1]
      },
      "minecraft:destructible_by_mining": {
        "seconds_to_destroy": 0.5
      },
      "minecraft:redstone_conductivity": {
        "allows_wire_to_step_down": true,
        "redstone_conductor": true
      },
      "minecraft:redstone_consumer": {
        "min_power": 1
      }
    },
    "permutations": [
      {
        "condition": "q.block_state('custom:is_active') == true",
        "components": {
          "minecraft:material_instances": {
            "*": {
              "texture": "iron_block",
              "render_method": "opaque"
            }
          }
        }
      },
      {
        "condition": "q.block_state('custom:is_finished') == true",
        "components": {
          "minecraft:light_emission": 15,
          "minecraft:material_instances": {
            "*": {
              "texture": "gold_block",
              "render_method": "opaque"
            }
          },
          "minecraft:redstone_producer": {
            "power": 15
          }
        }
      }
    ]
  }
}
